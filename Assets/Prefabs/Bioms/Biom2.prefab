  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9bdd32f66b449504d9c97f450258e74e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueLines:
  - This is the cage where Little Sunny is prisoned!
  - To save him you should get the green and orange keys!
  - You can obtain the keys by defeating 2 strong enemy!
  - Press "ENTER" near doors to change area!
  - 'Once you got all the keys come back! '
  - Then press "ENTER" in the middle of the giant door to get in there!
  - Good luck!
  dialogueManager: {fileID: 290345788898243944}
